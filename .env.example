# General app
FRONTEND_URL=http://localhost:5173
DB_PATH=data

# OpenAI LLM (backend only)
# Never expose this key in frontend code or public repos.
OPENAI_API_KEY=
OPENAI_MODEL_ORACLE=gpt-4o-mini
OPENAI_MODEL_CV=gpt-4o-mini
OPENAI_MODEL_REPO=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2

# Oracle generation controls
OPENAI_TEMPERATURE_ORACLE=0.7
OPENAI_TOP_P_ORACLE=1.0
OPENAI_MAX_TOKENS_ORACLE=600
OPENAI_ORACLE_APP_RETRIES=2
OPENAI_ORACLE_BACKOFF_BASE_MS=250
OPENAI_ORACLE_BACKOFF_MAX_MS=2000
OPENAI_ORACLE_BACKOFF_JITTER_MS=120
OPENAI_ORACLE_TOOL_ROUND_LIMIT=3

# LLM request guardrails
LLM_MAX_INSTRUCTIONS_CHARS=12000
LLM_MAX_INPUT_CHARS=24000
LLM_MAX_TOTAL_CHARS=32000

# CV generation controls
OPENAI_TEMPERATURE_CV=0.2
OPENAI_TOP_P_CV=1.0
OPENAI_MAX_TOKENS_CV=900

# Repo generation controls
OPENAI_TEMPERATURE_REPO=0.2
OPENAI_TOP_P_REPO=1.0
OPENAI_MAX_TOKENS_REPO=900

# GitHub API context (optional token helps with rate limits)
GITHUB_TOKEN=
GITHUB_TIMEOUT_SECONDS=10

# Logging and redaction
LOG_LEVEL=INFO
LOG_REDACTION_ENABLED=true

# Frontend/proxy (non-secret)
VITE_API_URL=/api
RAILWAY_BACKEND_URL=https://maibia-production.up.railway.app
